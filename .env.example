# MedLink Environment Configuration Template
# Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=medlink
DB_PORT=3306
DB_CHARSET=utf8mb4

# Application Settings
APP_NAME=MedLink
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true

# Base URLs
BASE_URL=http://localhost/MedLink
API_URL=http://localhost/MedLink/backend/api

# Security
SESSION_TIMEOUT=1800
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCK_TIMEOUT=900

# Email Configuration
EMAIL_FROM=noreply@medlink.com
EMAIL_FROM_NAME=MedLink System
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# File Upload
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# Pagination
ITEMS_PER_PAGE=20

# Timezone
TIMEZONE=UTC

# Logging
LOG_LEVEL=info
LOG_PATH=logs/

# API Settings
API_VERSION=1.0
API_RATE_LIMIT=100
